{
  "include": ["client/src/**/*", "shared/**/*", "server/**/*"],
  "exclude": ["node_modules", "build", "dist", "**/*.test.ts"],
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/typescript/tsbuildinfo",
    "noEmit": true,
    "module": "ESNext",
    "strict": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "types": ["node", "express"],
    "paths": {
      "@/*": ["./client/src/*"],
      "@client/*": ["./client/src/*"],
      "@client/shared/*": ["./client/src/shared/*"],
      "@client/assets/*": ["./client/src/assets/*"],
      "@client/entities/*": ["./client/src/entities/*"],
      "@client/features/*": ["./client/src/features/*"],
      "@client/lib/*": ["./client/src/lib/*"],
      "@client/pages/*": ["./client/src/pages/*"],
      "@client/store/*": ["./client/src/store/*"],
      "@client/types/*": ["./client/src/types/*"],
      "@client/utils/*": ["./client/src/utils/*"],
      "@client/widget/*": ["./client/src/widget/*"],
      "@server/*": ["./server/*"],
      "@server/shared/*": ["./server/shared/*"],
      "vite/client": ["./node_modules/vite/client.d.ts"]
    },
    "typeRoots": ["./node_modules/@types", "./server/types"]
  }
}
